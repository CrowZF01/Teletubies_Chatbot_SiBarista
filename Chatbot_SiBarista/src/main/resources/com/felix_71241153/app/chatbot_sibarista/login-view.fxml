<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #FFF4E0; -fx-border-color: #4B3832; -fx-border-width: 5;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <Label text="SiBarista" textFill="#4B3832">
            <font>
                <Font name="Serif Bold" size="36.0" />
            </font>
        </Label>
        <Label text="Admin Authentication" textFill="#6F4E37">
            <font>
                <Font name="System Italic" size="14.0" />
            </font>
        </Label>

        <VBox spacing="5.0">
            <children>
                <Label text="Username" textFill="#3E2723" />
                <TextField fx:id="usernameField" prefHeight="35.0" style="-fx-background-radius: 10; -fx-border-color: #C0A080; -fx-border-radius: 10;" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Password" textFill="#3E2723" />
                <PasswordField fx:id="passwordField" prefHeight="35.0" style="-fx-background-radius: 10; -fx-border-color: #C0A080; -fx-border-radius: 10;" />
            </children>
        </VBox>

        <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" prefWidth="320.0" style="-fx-background-color: #4B3832; -fx-background-radius: 20;" text="LOG IN" textFill="WHITE">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>

        <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: transparent;" text="Kembali ke Chat" textFill="#6F4E37" underline="true" />
    </children>
</VBox>