<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="450.0" spacing="0.0" style="-fx-background-color: white; -fx-background-radius: 15;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ProductFormController">

    <VBox spacing="5.0" style="-fx-background-color: #4A3020; -fx-padding: 25; -fx-background-radius: 15 15 0 0;">
        <Label fx:id="lblTitle" text="Tambah Menu Baru" textFill="#E8C882">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <Label text="Lengkapi informasi detail produk di bawah ini" textFill="#D4B896">
            <font><Font size="11.0" /></font>
        </Label>
    </VBox>

    <VBox spacing="15.0" style="-fx-padding: 25;">
        <HBox spacing="15.0">
            <VBox spacing="5.0">
                <Label text="ID DATABASE" textFill="#8B7560">
                    <font><Font name="System Bold" size="10.0" /></font>
                </Label>
                <TextField fx:id="txtId" editable="false" focusTraversable="false" mouseTransparent="true" prefWidth="80.0" style="-fx-background-color: #EEEAE5; -fx-border-color: #D4B896; -fx-border-radius: 5; -fx-alignment: CENTER; -fx-font-weight: bold;" text="AUTO" />
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="NAMA MENU" textFill="#8B7560"><font><Font name="System Bold" size="10.0" /></font></Label>
                <TextField fx:id="txtNama" promptText="Contoh: Caramel Macchiato" style="-fx-border-color: #D4B896; -fx-border-radius: 5;" />
            </VBox>
        </HBox>

        <HBox spacing="15.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="KATEGORI" textFill="#8B7560"><font><Font name="System Bold" size="10.0" /></font></Label>
                <ComboBox fx:id="cbKategori" maxWidth="Infinity" style="-fx-border-color: #D4B896; -fx-border-radius: 5;" />
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                <Label text="HARGA (RP)" textFill="#8B7560"><font><Font name="System Bold" size="10.0" /></font></Label>
                <TextField fx:id="txtHarga" promptText="25000" style="-fx-border-color: #D4B896; -fx-border-radius: 5;" />
            </VBox>
        </HBox>

        <VBox spacing="5.0">
            <Label text="DESKRIPSI" textFill="#8B7560"><font><Font name="System Bold" size="10.0" /></font></Label>
            <TextArea fx:id="txtDeskripsi" prefHeight="80.0" style="-fx-border-color: #D4B896; -fx-border-radius: 5;" wrapText="true" />
        </VBox>
      <VBox prefHeight="143.0" prefWidth="249.0">
         <children>
            <Label text="GAMBAR" textFill="#8B7560">
               <font>
                  <Font name="System Bold" size="10.0" />
               </font>
            </Label>
            <Label fx:id="lblNamaGambar" text="Gambar Kosong" textFill="#8B7560">
               <font>
                  <Font name="System Bold" size="10.0" />
               </font>
            </Label>
            <HBox prefHeight="25.0" prefWidth="231.0">
               <children>
                  <ImageView fx:id="imgPreview" fitHeight="126.0" fitWidth="183.0" pickOnBounds="true" preserveRatio="true" />
                  <Button mnemonicParsing="false" onAction="#handlePilihGambar" text="Pilih Gambar">
                     <HBox.margin>
                        <Insets left="50.0" top="50.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>

        <VBox spacing="8.0">
            <Label text="STATUS KETERSEDIAAN" textFill="#8B7560"><font><Font name="System Bold" size="10.0" /></font></Label>
            <HBox spacing="10.0">
                <Button fx:id="btnStokAda" onAction="#handleStokTersedia" prefHeight="35.0" prefWidth="180.0" text="✓ Tersedia" />
                <Button fx:id="btnStokHabis" onAction="#handleStokHabis" prefHeight="35.0" prefWidth="180.0" text="✕ Habis" />
            </HBox>
        </VBox>
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 0 25 25 25;">
        <Button onAction="#handleCancel" prefWidth="100.0" style="-fx-background-color: transparent; -fx-text-fill: #8B7560;" text="Batal" />
        <Button onAction="#handleSave" prefWidth="150.0" style="-fx-background-color: #4A3020; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Simpan Perubahan" />
    </HBox>

</VBox>
