<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ChatBotController"
            style="-fx-background-color: #EDEFF2;">

    <left>
        <VBox prefHeight="700.0" prefWidth="220.0" spacing="15.0"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;"
              BorderPane.alignment="CENTER">
            <children>
                <Label text="SiBarista">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="20.0" left="20.0" bottom="20.0" />
                    </VBox.margin>
                </Label>

                <VBox spacing="10.0">
                    <children>
                        <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false" text="Chat / Home"
                                style="-fx-background-color: #E8F0FE; -fx-background-radius: 8;">
                            <padding>
                                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
                            </padding>
                        </Button>

                        <Button alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false" text="About"
                                style="-fx-background-color: transparent; -fx-background-radius: 8;">
                            <padding>
                                <Insets top="10.0" right="14.0" bottom="10.0" left="14.0" />
                            </padding>
                        </Button>
                    </children>
                    <VBox.margin>
                        <Insets left="10.0" right="10.0" />
                    </VBox.margin>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Label text="sibarista">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                    <VBox.margin>
                        <Insets left="20.0" bottom="20.0" />
                    </VBox.margin>
                </Label>
            </children>
        </VBox>
    </left>

    <center>
        <VBox prefHeight="700.0" prefWidth="880.0" spacing="18.0"
              style="-fx-background-color: #F0F4F8;"
              BorderPane.alignment="CENTER">
            <children>

                <HBox alignment="CENTER_RIGHT" prefHeight="60.0">
                    <children>
                        <Button fx:id="adminModeButton" mnemonicParsing="false"
                                onAction="#handleAdminMode" text="Admin Mode" textFill="WHITE"
                                style="-fx-background-color: #111111; -fx-background-radius: 20;">
                            <padding>
                                <Insets bottom="5.0" left="15.0" right="15.0" top="5.0" />
                            </padding>
                        </Button>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" right="20.0" />
                    </VBox.margin>
                </HBox>

                <VBox fx:id="welcomeBox" alignment="CENTER" spacing="12.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="☕">
                            <font>
                                <Font size="56.0" />
                            </font>
                        </Label>

                        <Label text="Halo! Selamat datang di SiBarista">
                            <font>
                                <Font name="System Bold" size="30.0" />
                            </font>
                        </Label>

                        <Label text="Ketik pesan atau perintah untuk mulai chatting."
                               style="-fx-text-fill: #6B7280;" />

                        <StackPane maxWidth="540.0" style="-fx-background-color: white; -fx-background-radius: 18;">
                            <children>
                                <VBox spacing="14.0" maxWidth="500.0">
                                    <children>
                                        <TextField fx:id="messageField" onAction="#handleSend"
                                                   promptText="Ketik pesan atau perintah..."
                                                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 14px;" />
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Button onAction="#handleMenu" text="Menu" style="-fx-background-color: #E5E7EB; -fx-background-radius: 15;"/>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button fx:id="sendButton" mnemonicParsing="false" onAction="#handleSend"
                                                        prefHeight="34.0" prefWidth="34.0" text="↑" textFill="WHITE"
                                                        style="-fx-background-color: #000000; -fx-background-radius: 20;" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                            <padding>
                                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                            </padding>
                        </StackPane>
                    </children>
                </VBox>

                <VBox fx:id="chatAreaWrapper" spacing="14.0" visible="false" managed="false" VBox.vgrow="ALWAYS">
                    <children>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                                    VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="chatContainer" spacing="14.0" prefWidth="800.0">
                                    <padding>
                                        <Insets top="20.0" right="40.0" bottom="20.0" left="40.0" />
                                    </padding>
                                </VBox>
                            </content>
                        </ScrollPane>

                        <HBox alignment="CENTER_LEFT" spacing="10.0"
                              style="-fx-background-color: white; -fx-background-radius: 25;">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleMenu" text="Menu"
                                        style="-fx-background-color: #E5E7EB; -fx-background-radius: 15;" />
                                <TextField fx:id="chatInputField" onAction="#handleSendFromChat"
                                           promptText="Ketik pesan atau perintah..." HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 14px;" />
                                <Button mnemonicParsing="false" onAction="#handleSendFromChat"
                                        prefHeight="34.0" prefWidth="34.0" text="↑" textFill="WHITE"
                                        style="-fx-background-color: #111111; -fx-background-radius: 20;" />
                            </children>
                            <padding>
                                <Insets top="10.0" bottom="10.0" left="15.0" right="15.0"/>
                            </padding>
                            <VBox.margin>
                                <Insets left="40.0" right="40.0" bottom="20.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>
</BorderPane>