<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Rectangle?>

<!--
    SiBarista - Coffee Shop Chatbot UI
    Tema: Warm Espresso & Parchment
    Palette:
        #1C0A00  = Espresso Black (teks utama, aksen)
        #3D1A00  = Dark Roast (sidebar header)
        #6B3A2A  = Mocha (tombol aktif, aksen)
        #A0522D  = Sienna / Cinnamon (hover, ikon)
        #C8A882  = Latte Tan (border, divider)
        #F0E6D3  = Parchment Cream (bg utama)
        #FBF7F0  = Steamed Milk (bg sidebar, input)
        #FFFFFF  = Pure Foam (gelembung user bg)
-->

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="700.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ChatBotController"
            style="-fx-background-color: #F0E6D3;">

    <!-- ===== SIDEBAR KIRI ===== -->
    <left>
        <VBox prefHeight="700.0" prefWidth="230.0" spacing="0"
              style="-fx-background-color: #1C0A00;"
              BorderPane.alignment="CENTER">

            <!-- Logo Area -->
            <VBox style="-fx-background-color: #3D1A00;" alignment="CENTER_LEFT">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <children>
                            <Label text="☕" style="-fx-text-fill: #C8A882;">
                                <font><Font size="22.0" /></font>
                            </Label>
                            <VBox spacing="0">
                                <children>
                                    <Label text="SiBarista" style="-fx-text-fill: #FBF7F0;">
                                        <font><Font name="System Bold" size="17.0" /></font>
                                    </Label>
                                    <Label text="your coffee companion" style="-fx-text-fill: #C8A882;">
                                        <font><Font size="9.0" /></font>
                                    </Label>
                                </children>
                            </VBox>
                        </children>
                        <padding><Insets top="22.0" left="18.0" bottom="22.0" right="18.0"/></padding>
                    </HBox>
                </children>
            </VBox>

            <!-- Divider bawah logo -->
            <Region prefHeight="1" style="-fx-background-color: #6B3A2A;" maxWidth="1.7976931348623157E308"/>

            <!-- Spacer atas menu -->
            <Region prefHeight="18"/>

            <!-- Menu Navigasi -->
            <VBox spacing="4">
                <children>

                    <!-- Chat / Home (aktif) -->
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          style="-fx-background-color: #6B3A2A; -fx-background-radius: 8;">
                        <children>
                            <Label text="💬" style="-fx-text-fill: #FBF7F0;">
                                <font><Font size="14.0" /></font>
                            </Label>
                            <Label text="Chat / Home" style="-fx-text-fill: #FBF7F0;">
                                <font><Font name="System Bold" size="13.0" /></font>
                            </Label>
                        </children>
                        <padding><Insets top="10" left="14" bottom="10" right="14"/></padding>
                        <VBox.margin><Insets left="10" right="10"/></VBox.margin>
                    </HBox>

                    <!-- About -->
                    <HBox alignment="CENTER_LEFT" spacing="12"
                          style="-fx-background-color: transparent; -fx-background-radius: 8; -fx-cursor: hand;">
                        <children>
                            <Label text="📖" style="-fx-text-fill: #C8A882;">
                                <font><Font size="14.0" /></font>
                            </Label>
                            <Label text="About" style="-fx-text-fill: #C8A882;">
                                <font><Font size="13.0" /></font>
                            </Label>
                        </children>
                        <padding><Insets top="10" left="14" bottom="10" right="14"/></padding>
                        <VBox.margin><Insets left="10" right="10"/></VBox.margin>
                    </HBox>

                </children>
            </VBox>

            <!-- Spacer fleksibel -->
            <Region VBox.vgrow="ALWAYS" />

            <!-- Divider atas footer -->
            <Region prefHeight="1" style="-fx-background-color: #3D1A00;" maxWidth="1.7976931348623157E308"/>

            <!-- Footer Sidebar -->
            <VBox alignment="CENTER_LEFT" spacing="4">
                <children>
                    <Label text="sibarista" style="-fx-text-fill: #6B3A2A;">
                        <font><Font name="System Bold Italic" size="26.0" /></font>
                    </Label>
                    <Label text="v1.0 · Est. 2025" style="-fx-text-fill: #3D1A00;">
                        <font><Font size="10.0" /></font>
                    </Label>
                </children>
                <padding><Insets top="16" left="18" bottom="20" right="18"/></padding>
            </VBox>

        </VBox>
    </left>

    <!-- ===== AREA UTAMA ===== -->
    <center>
        <VBox prefHeight="700.0" prefWidth="870.0" spacing="0"
              style="-fx-background-color: #F0E6D3;"
              BorderPane.alignment="CENTER">

            <!-- Topbar -->
            <HBox alignment="CENTER_RIGHT" prefHeight="56"
                  style="-fx-background-color: #FBF7F0; -fx-border-color: #C8A882; -fx-border-width: 0 0 1 0;">
                <children>
                    <!-- Judul kecil tengah (dekoratif) -->
                    <Label text="☕  Selamat datang, silakan pesan!" style="-fx-text-fill: #A0522D;">
                        <font><Font size="12.0" /></font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="adminModeButton" mnemonicParsing="false"
                            onAction="#handleAdminMode" text="⚙  Admin Mode"
                            style="-fx-background-color: #1C0A00; -fx-text-fill: #C8A882; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 12px;">
                        <padding><Insets top="7" left="16" bottom="7" right="16"/></padding>
                    </Button>
                </children>
                <padding><Insets left="24" right="20"/></padding>
            </HBox>

            <!-- ===== HALAMAN WELCOME ===== -->
            <VBox fx:id="welcomeBox" alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
                <children>

                    <!-- Ikon besar -->
                    <Label text="☕">
                        <font><Font size="64.0" /></font>
                    </Label>

                    <!-- Judul utama -->
                    <VBox alignment="CENTER" spacing="6">
                        <children>
                            <Label text="Halo! Selamat datang di SiBarista"
                                   style="-fx-text-fill: #1C0A00;">
                                <font><Font name="System Bold" size="28.0" /></font>
                            </Label>
                            <Label text="Tanyakan menu, harga, atau rekomendasikan kopi favoritmu."
                                   style="-fx-text-fill: #A0522D;">
                                <font><Font size="13.0" /></font>
                            </Label>
                        </children>
                    </VBox>

                    <!-- Chip saran cepat -->
                    <HBox spacing="10" alignment="CENTER">
                        <children>
                            <Button text="☕ Lihat Menu" mnemonicParsing="false" onAction="#handleMenu"
                                    style="-fx-background-color: #FBF7F0; -fx-text-fill: #6B3A2A; -fx-border-color: #C8A882; -fx-border-width: 1; -fx-border-radius: 20; -fx-background-radius: 20; -fx-font-size: 12px; -fx-cursor: hand;">
                                <padding><Insets top="8" left="16" bottom="8" right="16"/></padding>
                            </Button>
                            <Button text="🌟 Rekomendasi" mnemonicParsing="false"
                                    style="-fx-background-color: #FBF7F0; -fx-text-fill: #6B3A2A; -fx-border-color: #C8A882; -fx-border-width: 1; -fx-border-radius: 20; -fx-background-radius: 20; -fx-font-size: 12px; -fx-cursor: hand;">
                                <padding><Insets top="8" left="16" bottom="8" right="16"/></padding>
                            </Button>
                            <Button text="💰 Harga" mnemonicParsing="false"
                                    style="-fx-background-color: #FBF7F0; -fx-text-fill: #6B3A2A; -fx-border-color: #C8A882; -fx-border-width: 1; -fx-border-radius: 20; -fx-background-radius: 20; -fx-font-size: 12px; -fx-cursor: hand;">
                                <padding><Insets top="8" left="16" bottom="8" right="16"/></padding>
                            </Button>
                        </children>
                    </HBox>

                    <!-- Input box -->
                    <StackPane maxWidth="560.0"
                               style="-fx-background-color: #FBF7F0; -fx-background-radius: 16; -fx-border-color: #C8A882; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(107,58,42,0.12), 12, 0, 0, 3);">
                        <children>
                            <VBox spacing="12.0" maxWidth="520.0">
                                <children>
                                    <TextField fx:id="messageField" onAction="#handleSend"
                                               promptText="Ketik pesan atau perintah..."
                                               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 14px; -fx-text-fill: #1C0A00; -fx-prompt-text-fill: #C8A882;" />
                                    <!-- Garis pemisah tipis -->
                                    <Region prefHeight="1" style="-fx-background-color: #C8A882;" maxWidth="1.7976931348623157E308"/>
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <children>
                                            <Button onAction="#handleMenu" text="☕ Menu"
                                                    style="-fx-background-color: #F0E6D3; -fx-text-fill: #6B3A2A; -fx-background-radius: 12; -fx-font-size: 12px; -fx-cursor: hand;">
                                                <padding><Insets top="6" left="12" bottom="6" right="12"/></padding>
                                            </Button>
                                            <Region HBox.hgrow="ALWAYS" />
                                            <Button fx:id="sendButton" mnemonicParsing="false"
                                                    onAction="#handleSend"
                                                    prefHeight="34.0" prefWidth="34.0" text="↑"
                                                    style="-fx-background-color: #1C0A00; -fx-text-fill: #C8A882; -fx-background-radius: 20; -fx-font-size: 16px; -fx-cursor: hand;" />
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>
                        </children>
                        <padding><Insets top="18.0" right="18.0" bottom="18.0" left="18.0" /></padding>
                    </StackPane>

                </children>
            </VBox>

            <!-- ===== AREA CHAT ===== -->
            <VBox fx:id="chatAreaWrapper" spacing="0" visible="false" managed="false" VBox.vgrow="ALWAYS">
                <children>

                    <!-- ScrollPane Percakapan -->
                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                                VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="chatContainer" spacing="16.0" prefWidth="800.0">
                                <padding>
                                    <Insets top="28.0" right="50.0" bottom="24.0" left="50.0" />
                                </padding>
                            </VBox>
                        </content>
                    </ScrollPane>

                    <!-- Garis pemisah -->
                    <Region prefHeight="1" style="-fx-background-color: #C8A882;" maxWidth="1.7976931348623157E308"/>

                    <!-- Input Bar Bawah -->
                    <HBox alignment="CENTER_LEFT" spacing="12.0"
                          style="-fx-background-color: #FBF7F0;">
                        <children>
                            <Button mnemonicParsing="false" onAction="#handleMenu" text="☕ Menu"
                                    style="-fx-background-color: #F0E6D3; -fx-text-fill: #6B3A2A; -fx-background-radius: 12; -fx-font-size: 12px; -fx-cursor: hand;">
                                <padding><Insets top="8" left="14" bottom="8" right="14"/></padding>
                            </Button>
                            <TextField fx:id="chatInputField" onAction="#handleSendFromChat"
                                       promptText="Ketik pesan atau tanya sesuatu..." HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 14px; -fx-text-fill: #1C0A00; -fx-prompt-text-fill: #C8A882;" />
                            <Button mnemonicParsing="false" onAction="#handleSendFromChat"
                                    prefHeight="36.0" prefWidth="36.0" text="↑"
                                    style="-fx-background-color: #1C0A00; -fx-text-fill: #C8A882; -fx-background-radius: 20; -fx-font-size: 16px; -fx-cursor: hand;" />
                        </children>
                        <padding><Insets top="14.0" bottom="14.0" left="50.0" right="50.0"/></padding>
                    </HBox>

                </children>
            </VBox>

        </VBox>
    </center>

</BorderPane>
