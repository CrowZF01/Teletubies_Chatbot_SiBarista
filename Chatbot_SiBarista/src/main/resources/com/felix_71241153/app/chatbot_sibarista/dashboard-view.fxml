<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="700.0" prefWidth="1000.0" spacing="0.0" style="-fx-background-color: #FDFBF9;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashBoardController">

    <!-- HEADER NAV -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #4A3020; -fx-padding: 15 30 15 30;">
        <Label text="☕ SiBarista" textFill="#E8C882">
            <font><Font name="Georgia Bold" size="24.0" /></font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="txtSearch" prefWidth="300.0" promptText="Cari produk atau kategori..." style="-fx-background-radius: 20; -fx-padding: 8 15; -fx-background-color: #634330; -fx-text-fill: white; -fx-prompt-text-fill: #A08060;" />
        <Button onAction="#handleLogout" style="-fx-background-color: #E8C882; -fx-text-fill: #4A3020; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand;" text="Log Out" />
    </HBox>

    <!-- STATISTICS CARDS -->
    <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 20 30 20 30; -fx-background-color: #F5F0EA;">
        <VBox alignment="CENTER" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <Label text="Total Menu" textFill="#8B7560"><font><Font size="12.0" /></font></Label>
            <Label fx:id="lblTotalProduk" text="0" textFill="#4A3020"><font><Font name="System Bold" size="28.0" /></font></Label>
        </VBox>
        <VBox alignment="CENTER" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <Label text="Tersedia" textFill="#8B7560"><font><Font size="12.0" /></font></Label>
            <Label fx:id="lblTersedia" text="0" textFill="#3AB07A"><font><Font name="System Bold" size="28.0" /></font></Label>
        </VBox>
        <VBox alignment="CENTER" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <Label text="Habis" textFill="#8B7560"><font><Font size="12.0" /></font></Label>
            <Label fx:id="lblHabis" text="0" textFill="#C44A4A"><font><Font name="System Bold" size="28.0" /></font></Label>
        </VBox>
    </HBox>

    <!-- CONTENT -->
    <VBox spacing="15.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 30 20 30;">
        <HBox alignment="CENTER_LEFT">
            <Label text="Daftar Menu Café" textFill="#4A3020">
                <font><Font name="System Bold" size="20.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleAdd" style="-fx-background-color: #4A3020; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8;" text="+ Tambah Produk Baru" />
        </HBox>

        <TableView fx:id="productTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #D4B896;">
            <columns>
                <TableColumn fx:id="colNo" prefWidth="70.0" text="NO" />
                <TableColumn fx:id="colNama" prefWidth="200.0" text="Nama Produk" />
                <TableColumn fx:id="colKategori" prefWidth="120.0" text="Kategori" />
                <TableColumn fx:id="colDeskripsi" prefWidth="250.0" text="Deskripsi" />
                <TableColumn fx:id="colHarga" prefWidth="120.0" text="Harga (Rp)" />
                <TableColumn fx:id="colStok" prefWidth="120.0" text="Status Stok" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <Button onAction="#handleEdit" prefWidth="120.0" style="-fx-background-color: transparent; -fx-border-color: #4A3020; -fx-border-radius: 8; -fx-text-fill: #4A3020;" text="✎ Edit Data" />
            <Button onAction="#handleDelete" prefWidth="120.0" style="-fx-background-color: #FFE5E5; -fx-text-fill: #C44A4A; -fx-font-weight: bold; -fx-background-radius: 8;" text="✕ Hapus" />
        </HBox>
    </VBox>
</VBox>