<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #FFF4E0;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashBoardController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #4B3832; -fx-padding: 15; -fx-background-radius: 15;">
            <children>
                <Label text="SiBarista Management" textFill="#FFF4E0">
                    <font>
                        <Font name="Serif Bold" size="24.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: #C0A080; -fx-text-fill: white; -fx-background-radius: 10;" text="Keluar Admin" />
            </children>
        </HBox>

        <TableView fx:id="productTable" prefHeight="400.0" prefWidth="860.0" style="-fx-background-color: white; -fx-border-color: #C0A080; -fx-selection-bar: #C0A080;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="80.0" text="ID" />
                <TableColumn fx:id="colNama" prefWidth="200.0" text="Nama Produk" />
                <TableColumn fx:id="colKategori" prefWidth="120.0" text="Kategori" />
                <TableColumn fx:id="colDeskripsi" prefWidth="200.0" text="Deskripsi" />
                <TableColumn fx:id="colHarga" prefWidth="120.0" text="Harga" />
                <TableColumn fx:id="colStok" prefWidth="120.0" text="Status Stok" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleAdd" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #4B3832; -fx-text-fill: white; -fx-background-radius: 10;" text="Tambah Baru" />
                <Button mnemonicParsing="false" onAction="#handleEdit" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #6F4E37; -fx-text-fill: white; -fx-background-radius: 10;" text="Edit Data" />
                <Button mnemonicParsing="false" onAction="#handleDelete" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #8B0000; -fx-text-fill: white; -fx-background-radius: 10;" text="Hapus" />
            </children>
        </HBox>
    </children>
</VBox>